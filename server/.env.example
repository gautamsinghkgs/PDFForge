# ── Server Config ──
PORT=5000
NODE_ENV=development

# ── MongoDB ──
# Local:    mongodb://localhost:27017/pdfforge
# Atlas:    mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/pdfforge
MONGO_URI=mongodb://localhost:27017/pdfforge

# ── JWT ──
JWT_SECRET=change_this_to_a_random_string
JWT_EXPIRE=1d

# ── File Upload ──
MAX_FILE_SIZE=104857600
UPLOAD_PATH=./uploads

# ── Client URL (CORS) ──
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app
CLIENT_URL=http://localhost:3000

# ── System Tools Paths ──
# Windows examples:
# GHOSTSCRIPT_PATH=C:\Program Files\gs\gs10.07.0\bin\gswin64c.exe
# LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
# Linux/macOS: usually on PATH, leave empty to auto-detect
GHOSTSCRIPT_PATH=
LIBREOFFICE_PATH=

# ── Razorpay Payment Gateway ──
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Cluster (optional) ──
# Number of worker processes. Defaults to CPU count (max 8)
# CLUSTER_WORKERS=4
